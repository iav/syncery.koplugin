msgstr "SDR sidecar"

#: syncery_ui/menu/init.lua
#, lua-format
msgid "Storage mode: %s"
msgstr "Режим на съхранение: %s"

#: syncery_ui/menu/init.lua
msgid "SDR keeps files in each book's sidecar folder; Synceryhash keeps them by content so they survive renames."
msgstr "SDR пази файловете в sidecar папката на всяка книга; Synceryhash ги пази по съдържание, така че те оцеляват при преименуване."

#: syncery_ui/menu/init.lua
msgid "Choose where Syncery stores its JSON files: SDR sidecars or a Synceryhash directory."
msgstr "Изберете къде Syncery да съхранява своите JSON файлове: SDR sidecar папки или Synceryhash директория."

#: syncery_ui/menu/init.lua
#, lua-format
msgid "This device: %s"
msgstr "Това устройство: %s"

#: syncery_ui/menu/init.lua
msgid "Rename this device or view its ID."
msgstr "Преименувайте това устройство или вижте идентификатора му."

#: syncery_ui/menu/init.lua
msgid "The name other devices see for this one, and its unique ID."
msgstr "Името, което другите устройства виждат за това, и уникалният му идентификатор."

#: syncery_ui/menu/init.lua
msgid "Delete and reset"
msgstr "Изтриване и нулиране"

#: syncery_ui/menu/init.lua
msgid "Destructive operations: deep clean this book's files, or reset all Syncery settings."
msgstr "Разрушителни операции: дълбоко почистване на файловете на тази книга или нулиране на всички настройки на Syncery."

#: syncery_ui/menu/init.lua
msgid "Deep clean (permanently delete this book's JSON files) and reset-all-settings live here. Each confirms before acting."
msgstr "Дълбокото почистване (окончателно изтриване на JSON файловете на тази книга) и нулирането на всички настройки са тук. Всяко иска потвърждение, преди да действа."

#: syncery_ui/menu/init.lua syncery_ui/wizard.lua
msgid "progress"
msgstr "напредък"

#: syncery_ui/menu/init.lua syncery_ui/wizard.lua
msgid "annotations"
msgstr "анотации"

#: syncery_ui/menu/init.lua
msgid "metadata"
msgstr "метаданни"

