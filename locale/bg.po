msgid_plural "Removed %d orphaned sync files."
msgstr[0] "Премахнат е %d осиротял файл за синхронизиране."
msgstr[1] "Премахнати са %d осиротели файла за синхронизиране."

#: syncery_ui/booklist/actions.lua
msgid "Reset my Syncery data for this book"
msgstr "Нулирай данните ми в Syncery за тази книга"

#: syncery_ui/booklist/actions.lua
msgid ""
"Reset this device's annotations and progress for this book?\n"
"\n"
"Reading status, rating, and render settings stay. Only this device's annotations and progress are cleared; those from your other devices are kept."
msgstr ""
"Да нулирам ли анотациите и напредъка на това устройство за тази книга?\n"
"\n"
"Състоянието на четене, оценката и настройките за изобразяване остават. Само данните на това устройство — анотации и напредък — се изчистват; тези от другите ви устройства се запазват."

#: syncery_ui/annotation_viewer/viewer_lifted.lua
#: syncery_ui/progress_browser/init.lua
msgid "Resolve"
msgstr "Разреши"

#: syncery_ui/annotation_viewer/viewer_lifted.lua
