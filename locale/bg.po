#: main.lua
msgid "Syncery can't identify this book reliably, so it won't sync across your devices. This usually means the file couldn't be read fully."
msgstr "Syncery не може да разпознае надеждно тази книга, затова тя няма да се синхронизира между устройствата ви. Това обикновено означава, че файлът не може да бъде прочетен изцяло."

#: main.lua
msgid "Syncery ran into an unexpected error while opening this book."
msgstr "Syncery срещна неочаквана грешка при отваряне на тази книга."

