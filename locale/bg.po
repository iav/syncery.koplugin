#: syncery_ui/menu/advanced_section.lua
msgid "Deep clean – permanently erase all book data…"
msgstr "Дълбоко почистване – окончателно изтриване на всички данни на книгата…"

#: syncery_ui/menu/advanced_section.lua
msgid "Open a book first — deep clean operates on the current book."
msgstr "Първо отворете книга — дълбокото почистване работи върху текущата книга."

#: syncery_ui/menu/advanced_section.lua
msgid "Tap to permanently delete the Syncery JSON files for this book."
msgstr "Докоснете, за да изтриете окончателно JSON файловете на Syncery за тази книга."

#: main.lua syncery_ui/menu/advanced_section.lua
